{
    "functions": {
        "app/api/search/route.ts": {
            "maxDuration": 30
        },
        "app/api/scraper/run/route.ts": {
            "maxDuration": 60
        },
        "app/api/cron/refresh-cache/route.ts": {
            "maxDuration": 60
        },
        "app/api/cron/deals/route.ts": {
            "maxDuration": 60
        },
        "app/api/cron/deal-notifications/route.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        { "path": "/api/cron/deal-notifications", "schedule": "0 8 * * *" },
        { "path": "/api/cron/deals", "schedule": "0 */2 * * *" },
        { "path": "/api/cron/cleanup", "schedule": "0 3 * * 0" },
        { "path": "/api/cron/refresh-cache", "schedule": "0 */6 * * *" }
    ]
}