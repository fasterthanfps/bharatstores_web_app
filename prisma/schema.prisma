generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String
  slug        String    @unique
  category    String?
  brand       String?
  imageUrl    String?   @map("image_url")
  searchTerms String[]  @map("search_terms")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  listings    Listing[]
  
  @@map("products")
}

model Store {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  name        String
  domain      String    @unique
  logoUrl     String?   @map("logo_url")
  baseUrl     String    @map("base_url")
  isActive    Boolean   @default(true) @map("is_active")
  scraperType String    @map("scraper_type")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  
  listings    Listing[]
  scraperRuns ScraperRun[]
  
  @@map("stores")
}

model Listing {
  id            String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  productId     String?   @map("product_id") @db.Uuid
  storeId       String?   @map("store_id") @db.Uuid
  storeName     String    @map("store_name")
  price         Decimal   @db.Decimal
  comparePrice  Decimal?  @map("compare_price") @db.Decimal
  currency      String    @default("EUR")
  availability  String
  productUrl    String    @map("product_url")
  imageUrl      String?   @map("image_url")
  weightGrams   Int?      @map("weight_grams")
  weightLabel   String?   @map("weight_label")
  pricePerKg    Decimal?  @map("price_per_kg") @db.Decimal
  lastScrapedAt DateTime  @default(now()) @map("last_scraped_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  product       Product?  @relation(fields: [productId], references: [id])
  store         Store?    @relation(fields: [storeId], references: [id])
  priceAlerts   PriceAlert[]
  priceHistory  PriceHistory[]
  clicks        Click[]
  
  @@map("listings")
}

model ScraperRun {
  id            String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  storeId       String?   @map("store_id") @db.Uuid
  status        String?
  productsFound Int?      @default(0) @map("products_found")
  errors        Json?
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)
  
  store         Store?    @relation(fields: [storeId], references: [id])
  
  @@map("scraper_runs")
}

model PriceAlert {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  listingId   String?   @map("listing_id") @db.Uuid
  targetPrice Decimal   @map("target_price") @db.Decimal
  isTriggered Boolean   @default(false) @map("is_triggered")
  notifiedAt  DateTime? @map("notified_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  
  listing     Listing?  @relation(fields: [listingId], references: [id])
  
  @@map("price_alerts")
}

model PriceHistory {
  id            String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  listingId     String?   @map("listing_id") @db.Uuid
  price         Decimal   @db.Decimal
  availability  String
  recordedAt    DateTime  @default(now()) @map("recorded_at") @db.Timestamptz(6)
  
  listing       Listing?  @relation(fields: [listingId], references: [id])
  
  @@map("price_history")
}

model Click {
  id          String    @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  listingId   String?   @map("listing_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  sessionId   String    @map("session_id")
  ipHash      String?   @map("ip_hash")
  referrer    String?
  converted   Boolean   @default(false)
  revenueEur  Decimal?  @map("revenue_eur") @db.Decimal
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  
  listing     Listing?  @relation(fields: [listingId], references: [id])
  
  @@map("clicks")
}

model SearchEvent {
  id              String   @id @default(dbgenerated("extensions.uuid_generate_v4()")) @db.Uuid
  query           String
  normalizedQuery String   @map("normalized_query")
  resultsCount    Int      @map("results_count")
  sessionId       String?  @map("session_id")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("search_events")
}
